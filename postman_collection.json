{
  "info": {
    "name": "GitHub Profile Analyzer API",
    "description": "Complete collection for the GitHub Profile Analyzer backend assignment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "username",
      "value": "octocat"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/analyze/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "analyze", "{{username}}"]
        }
      }
    },
    {
      "name": "Get All Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/profiles?page=1&limit=10&sortBy=followers&order=DESC&search=",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "profiles"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "sortBy", "value": "followers" },
            { "key": "order", "value": "DESC" },
            { "key": "search", "value": "" }
          ]
        }
      }
    },
    {
      "name": "Get Single Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/profile/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "profile", "{{username}}"]
        }
      }
    },
    {
      "name": "Refresh Profile",
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/refresh/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "refresh", "{{username}}"]
        }
      }
    },
    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/profile/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "profile", "{{username}}"]
        }
      }
    }
  ]
}
